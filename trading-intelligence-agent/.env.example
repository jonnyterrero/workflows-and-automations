# Trading Intelligence Agent — environment template (copy to .env, never commit .env)

# ── Mode ──────────────────────────────────────────────────────────────────────
DEMO_MODE=false

# ── Market data ───────────────────────────────────────────────────────────────
# Polygon/Massive preferred for equities & ETFs (faster than Alpha Vantage)
POLYGON_API_KEY=
# Alpha Vantage fallback (free: 5 req/min)
ALPHA_VANTAGE_API_KEY=

# ── Corporate fundamentals / catalysts ────────────────────────────────────────
# Finnhub powers company news, basic financials, earnings calendar, and IPO calendar
FINNHUB_API_KEY=

# SEC-API.io optional filing search upgrade; EDGAR public endpoint remains fallback
SEC_API_KEY=

# ── Macro (FRED — free) ───────────────────────────────────────────────────────
FRED_API_KEY=

# ── News: equities & macro (RSS — free, no key) ───────────────────────────────
# Bloomberg Markets, Yahoo Finance, CNBC, MarketWatch, Investing.com
RSS_FEED_URLS=https://feeds.bloomberg.com/markets/news.rss,https://finance.yahoo.com/news/rssindex,https://feeds.marketwatch.com/marketwatch/topstories/,https://search.cnbc.com/rs/search/combinedcms/view.xml?partnerId=wrss01&id=10000664,https://www.investing.com/rss/news_25.rss

# ── News: crypto (RSS catalog in config/crypto_rss_feeds.yaml) ───────────────
# Leave empty to use 15 curated feeds. Override with comma-separated URLs:
CRYPTO_RSS_FEED_URLS=

# NewsAPI free dev tier (100 req/day, non-commercial — fine for personal agent)
NEWSAPI_KEY=
NEWSAPI_MAX_CALLS_PER_RUN=3

# ── Social ────────────────────────────────────────────────────────────────────
REDDIT_SUBREDDITS=investing,wallstreetbets,stocks,CryptoCurrency,StockMarket
REDDIT_USER_AGENT=trading-intelligence-agent/0.1 (by /u/trading_intel_bot)

# X API v2 — Bearer Token from developer.x.com (paste decoded token, not URL-encoded)
X_BEARER_TOKEN=
# Optional custom search (use {symbol} placeholder):
# X_CRYPTO_SEARCH_QUERY=({symbol} OR bitcoin) -is:retweet lang:en
# X_EQUITY_SEARCH_QUERY=${symbol} OR {symbol} -is:retweet lang:en

# ── SEC EDGAR (free — User-Agent required) ────────────────────────────────────
EDGAR_USER_AGENT=trading-intelligence-agent/0.1 (your-email@example.com)

# ── Crypto market data ────────────────────────────────────────────────────────
# Coinbase Exchange public market data is used by default; private credentials are
# not required for candles/ticker/order book and should not be exposed client-side.
COINBASE_USE_PUBLIC_MARKET_DATA=true
COINBASE_API_KEY=
COINBASE_API_SECRET=
ENABLE_IPOSCOOP_SCRAPER=true

# ── LLM (optional) ────────────────────────────────────────────────────────────
LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/trading_intel.db
FIREBASE_PROJECT_ID=demo-trading-intel

# ── Watchlists ────────────────────────────────────────────────────────────────
DEFAULT_WATCHLIST=SPY,QQQ,TLT,AAPL,NVDA,TSLA,BTC-USD,ETH-USD
DEFAULT_CRYPTO_WATCHLIST=BTC-USD,ETH-USD,SOL-USD
DAILY_JOB_CRON=0 6 * * *
